pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        GITHUB_REPO  = "KB-iGOT/sunbird-nodebb"
        GITHUB_API   = "https://api.github.com/repos/${GITHUB_REPO}"

        SONARQUBE_ENV       = "sonarqube"
        SONAR_SCANNER_HOME  = "/var/lib/jenkins/sonar-scanner-7.3.0.5189-linux-x64"
    }

    stages {

        stage("PR Context Check") {
            when { changeRequest() }
            steps {
                echo "PR #${CHANGE_ID}"
                echo "From: ${CHANGE_BRANCH}"
                echo "To  : ${CHANGE_TARGET}"
                echo "Fork: ${CHANGE_FORK ?: false}"
            }
        }

        stage("Checkout PR") {
            when { changeRequest() }
            steps {
                checkout scm
            }
        }

        stage("Sonar Analysis") {
            when { changeRequest() }
            steps {
                withSonarQubeEnv("${SONARQUBE_ENV}") {
                    sh """
                      ${SONAR_SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectKey=${JOB_NAME.replaceAll('/', '_')} \
                        -Dsonar.sources=.
                    """
                }
            }
        }

        stage("Quality Gate") {
            when { changeRequest() }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "✅ Quality Gate Passed"
            }
        }
    }

    post {
        success {
            echo "✅ PR validation successful. Waiting for manager merge."
        }
        failure {
            echo "❌ PR validation failed — merge is BLOCKED"
        }
    }
}

